# ==============================================================================
# Anthropic API
# ==============================================================================
# Get yours at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Model to use for security analysis
# Recommended: claude-sonnet-4-5 (good balance of capability and cost: $3/$15 per M tokens)
# Alternative: claude-opus-4-6 for higher quality, slower, more expensive ($15/$75 per M tokens)
CLAUDE_MODEL=claude-sonnet-4-5

# ==============================================================================
# Database (Postgres on Neon recommended)
# ==============================================================================
# Get a free Postgres instance at https://neon.tech
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=

# ==============================================================================
# GitHub App (needed from Weekend 2 onwards)
# ==============================================================================
# Create your GitHub App at https://github.com/settings/apps/new
# See docs/SETUP.md for the exact permissions and webhook URL to configure
GITHUB_APP_ID=
GITHUB_APP_WEBHOOK_SECRET=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=

# Paste the contents of your downloaded .pem private key here.
# Escape newlines as \n, or use a single-line PEM in a secret manager in production.
GITHUB_APP_PRIVATE_KEY=

# ==============================================================================
# App configuration
# ==============================================================================
# Public URL of your deployment (Vercel will set this automatically in prod)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Free tier limits
FREE_TIER_SCANS_PER_MONTH=50

# ==============================================================================
# Stripe (Weekend 4 — leave blank until you add billing)
# ==============================================================================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=
