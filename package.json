{
  "name": "ai-code-security-reviewer",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered code security reviewer for indie hackers and small teams. Runs Semgrep + Claude on every PR, posts findings as PR comments.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "scan": "tsx scripts/scan-local.ts",
    "scan:bench": "tsx scripts/scan-local.ts --bench",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@octokit/app": "^16.0.2",
    "@octokit/rest": "^21.0.2",
    "@octokit/webhooks": "^13.4.1",
    "@prisma/client": "^6.0.1",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "dotenv": "^16.4.7",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.4.49",
    "prisma": "^6.0.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
